		<query>ВЫБРАТЬ
	0 КАК Факт,
	БюджетОбороты.СуммаРасход КАК БюджетОстаток,
	БюджетОбороты.СуммаРасход КАК Бюджет,
	БюджетОбороты.Статья КАК Статья,
	НАЧАЛОПЕРИОДА(БюджетОбороты.Период, МЕСЯЦ) КАК Период,
	БюджетОбороты.Регистратор КАК Регистратор
ИЗ
	РегистрНакопления.БюджетДоходы.Обороты(&amp;ДатаН, &amp;ДатаК, Регистратор, Проект = &amp;Проект) КАК БюджетОбороты

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	БюджетОбороты.СуммаПриход,
	-БюджетОбороты.СуммаПриход,
	0,
	БюджетОбороты.Статья,
	НАЧАЛОПЕРИОДА(БюджетОбороты.Период, МЕСЯЦ),
	БюджетОбороты.Регистратор
ИЗ
	РегистрНакопления.БюджетДоходы.Обороты(&amp;ДатаН, &amp;ДатаФактРасходов, Регистратор, Проект = ЗНАЧЕНИЕ(справочник.Проекты.ПустаяСсылка)) КАК БюджетОбороты</query>
