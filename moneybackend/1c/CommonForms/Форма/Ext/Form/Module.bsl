
&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбновитьНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДвиженияДСОстатки.Кошелек КАК Кошелек,
		|	ДвиженияДСОстатки.СуммаОстаток КАК Сумма,
		|	NULL КАК Статья,
		|	NULL КАК Перерасход
		|ИЗ
		|	РегистрНакопления.ДвиженияДС.Остатки(
		|			&КонецВыбранныйМесяц,
		|			ВЫБОР
		|				КОГДА &Скрыть
		|					ТОГДА НЕ Кошелек.Скрыть
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ) КАК ДвиженияДСОстатки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	""Бюджет расходы"",
		|	ВЫБОР
		|		КОГДА БюджетОстатки.СуммаОборот > 0
		|			ТОГДА 0
		|		ИНАЧЕ -БюджетОстатки.СуммаОборот
		|	КОНЕЦ,
		|	БюджетОстатки.Статья,
		|	ВЫБОР
		|		КОГДА БюджетОстатки.СуммаОборот > 0
		|			ТОГДА БюджетОстатки.СуммаОборот
		|		ИНАЧЕ 0
		|	КОНЕЦ
		|ИЗ
		|	РегистрНакопления.БюджетРасходы.Обороты(&НачалоВыбранныйМесяц, &КонецВыбранныйМесяц, , Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)) КАК БюджетОстатки
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сумма УБЫВ,
		|	Перерасход УБЫВ
		|АВТОУПОРЯДОЧИВАНИЕ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДвиженияДСОбороты.Период КАК Период,
		|	ДвиженияДСОбороты.СуммаРасход КАК СуммаРасход,
		|	ДвиженияДСОбороты.СуммаПриход КАК СуммаПриход
		|ИЗ
		|	РегистрНакопления.ДвиженияДС.Обороты(&НачалоПрошлогоМесяца, &КонецВыбранныйМесяц, Месяц, Статья <> ЗНАЧЕНИЕ(справочник.Статьи.ПустаяСсылка)) КАК ДвиженияДСОбороты
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	-БюджетОстатки.СуммаОборот КАК СуммаОборот
		|ИЗ
		|	РегистрНакопления.БюджетДоходы.Обороты(&НачалоТекущийМесяц, &КонецВыбранныйМесяц, , Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)) КАК БюджетОстатки";
	
	Запрос.УстановитьПараметр("Скрыть",Скрыть);
	Запрос.УстановитьПараметр("НачалоВыбранныйМесяц",НачалоМесяца(НаДату)); 
	Запрос.УстановитьПараметр("КонецВыбранныйМесяц",КонецДня(НаДату));
	Запрос.УстановитьПараметр("НачалоТекущийМесяц",НачалоМесяца(ТекущаяДатаСеанса())); 
	НачалоПрошлогоМесяца = НачалоМесяца(ДобавитьМесяц(НаДату,-1));
	Запрос.УстановитьПараметр("НачалоПрошлогоМесяца",НачалоПрошлогоМесяца);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса[0].Выбрать();
	Остатки.Очистить();
	СуммаБюджет = 0;
	
	Перерасход = 0;
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Наименование", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	ТЗ.Колонки.Добавить("Перерасход", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
    ТЗ.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(100)));
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.Кошелек = "Бюджет расходы" Тогда
			СуммаБюджет =  СуммаБюджет + ВыборкаДетальныеЗаписи.Сумма;
			Перерасход =  Перерасход + ВыборкаДетальныеЗаписи.Перерасход;

			//БюджетНазваниеСтатей  = БюджетНазваниеСтатей+ ?(ЗначениеЗаполнено(БюджетНазваниеСтатей),Символы.ПС,"")
			//	+ ВыборкаДетальныеЗаписи.Статья.Наименование + ": "+ Формат(ВыборкаДетальныеЗаписи.Сумма,"ЧДЦ=2");
			СтрокаТЗ = ТЗ.Добавить();
			СтрокаТЗ.Наименование = ВыборкаДетальныеЗаписи.Статья.Наименование;
			СтрокаТЗ.Сумма = Формат(ВыборкаДетальныеЗаписи.Сумма,"ЧДЦ=2");
			СтрокаТЗ.Перерасход = Формат(ВыборкаДетальныеЗаписи.Перерасход,"ЧДЦ=2");
			
				//БюджетОстатки  = БюджетОстатки+ ?(ЗначениеЗаполнено(БюджетОстатки),Символы.ПС + Символы.ПС,"")
		
		иначе
			строка = остатки.Добавить();
			ЗаполнитьЗначенияСвойств(строка,ВыборкаДетальныеЗаписи);
		КонецЕсли; 
		
		
	КонецЦикла;
	ИтогиПоТЧ		= Остатки.Итог("Сумма");
	Элементы.ОстаткиСумма.ТекстПодвала = Формат(ИтогиПоТЧ,"ЧДЦ=2");
	
	//БюджетОстатки =  "Итого: " + Формат(СуммаБюджет,"ЧДЦ=2")
	//	+ Символы.ПС + "Остаток ДС с учетом бюджета: " + Формат(ИтогиПоТЧ + СуммаБюджет,"ЧДЦ=2");
		
	СтрокаТЗ = ТЗ.Добавить();СтрокаТЗ = ТЗ.Добавить();
	СтрокаТЗ.Наименование = "Итого:";
	СтрокаТЗ.Сумма = Формат(СуммаБюджет,"ЧДЦ=2");
	СтрокаТЗ.Перерасход = Формат(Перерасход,"ЧДЦ=2");
	
	
	ВыборкаБюджетДоходы = РезультатЗапроса[2].Выбрать();
	СуммаБюджетДоходы = 0;
   	Если ВыборкаБюджетДоходы.Следующий() Тогда
		СуммаБюджетДоходы = ВыборкаБюджетДоходы.СуммаОборот;
	КонецЕсли;
	
	СтрокаТЗ = ТЗ.Добавить();
	СтрокаТЗ.Наименование = "Остаток ДС с учетом бюджета:";
	СтрокаТЗ.Сумма = Формат(ИтогиПоТЧ - СуммаБюджет + СуммаБюджетДоходы,"ЧДЦ=2");
		
	ВыборкаПриходыРасходы = РезультатЗапроса[1].Выбрать();
	РасходыПрошлыйМесяц = 0;
	РасходыТекущийМесяц = 0;
	ПриходыПрошлыйМесяц = 0;
	ПриходыТекущийМесяц = 0;

	Пока ВыборкаПриходыРасходы.Следующий() Цикл
		Если ВыборкаПриходыРасходы.Период = НачалоПрошлогоМесяца Тогда
			РасходыПрошлыйМесяц =  ВыборкаПриходыРасходы.СуммаРасход;
			ПриходыПрошлыйМесяц =  ВыборкаПриходыРасходы.СуммаПриход;
		ИначеЕсли ВыборкаПриходыРасходы.Период = НачалоМесяца(НаДату) Тогда
			РасходыТекущийМесяц =  ВыборкаПриходыРасходы.СуммаРасход;
			ПриходыТекущийМесяц =  ВыборкаПриходыРасходы.СуммаПриход;

		КонецЕсли; 
	КонецЦикла;
	Если РасходыПрошлыйМесяц = 0 Тогда
		РасхождениеРасходы = 0;
	иначе
		РасхождениеРасходы = (РасходыПрошлыйМесяц - РасходыТекущийМесяц)/РасходыПрошлыйМесяц*100;		
	КонецЕсли; 
		
	Если ПриходыТекущийМесяц = 0 Тогда
		РасхождениеПриходы = 100;
	иначе
		РасхождениеПриходы = (ПриходыТекущийМесяц- ПриходыПрошлыйМесяц )/ПриходыТекущийМесяц*100;		
	КонецЕсли; 
	
	СтруктураПараметры = Новый Структура;
	//СтруктураПараметры.Вставить("ПунктПорядкуИспользуется",ИСТИНА);
	//СтруктураПараметры.Вставить("ЦветШапки","eadbaf");
		СтруктураПараметры.Вставить("Заголовок1","Статья");
		СтруктураПараметры.Вставить("Заголовок2","Перерасход");
		СтруктураПараметры.Вставить("Заголовок3","Остаток");

	HTMLВиджет2 = СтрШаблон(ПолучитьТекстHTML2(),ТаблицаЗначенийВТаблицуХТМЛ(ТЗ,СтруктураПараметры));

	
	
	
	HTMLВиджет1 = СтрШаблон(ПолучитьТекстHTML1(),
	
	Формат(РасходыПрошлыйМесяц,"ЧДЦ=2; ЧН=0,00"),
	Формат(ПриходыПрошлыйМесяц,"ЧДЦ=2; ЧН=0,00"),
	Формат(РасходыТекущийМесяц,"ЧДЦ=2; ЧН=0,00"),
	Формат(ПриходыТекущийМесяц,"ЧДЦ=2; ЧН=0,00"),
	?(РасхождениеРасходы<0,"<td data-negative>","<td data-positive>")
	 + Формат(РасхождениеРасходы,"ЧДЦ=2") + "&#37;</td>",
	 ?(РасхождениеПриходы<0,"<td data-negative>","<td data-positive>")
	 + Формат(РасхождениеПриходы,"ЧДЦ=2") + "&#37;</td>");

КонецПроцедуры

