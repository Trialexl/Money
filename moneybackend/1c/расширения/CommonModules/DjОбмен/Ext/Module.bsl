Процедура ПрименитьИзменениеСайта(Изменение)
	Маршрут = ПолучитьЗначениеJSON(Изменение, "route", "");
	Операция = ПолучитьЗначениеJSON(Изменение, "operation", "");
	ПолезнаяНагрузка = ПолучитьЗначениеJSON(Изменение, "payload");
	Идентификатор = ПолучитьЗначениеJSON(ПолезнаяНагрузка, "id", "");
	
	Если ПустаяСтрока(Маршрут) Тогда
		ВызватьИсключение "В изменении сайта не указан маршрут.";
	КонецЕсли;
	Если ПустаяСтрока(Идентификатор) Тогда
		ВызватьИсключение "В payload не указан идентификатор объекта.";
	КонецЕсли;
	
	Если Операция = "delete" Тогда
		ПрименитьПометкуУдаления(Маршрут, Идентификатор, ПолезнаяНагрузка);
		Возврат;
	КонецЕсли;
	
	Объект = ПолучитьИлиСоздатьОбъектПоМаршруту(Маршрут, Идентификатор);
	ЗаполнитьОбъектИзСайта(Маршрут, Объект, ПолезнаяНагрузка);
	ЗаписатьОбъектИзОбмена(Объект);
КонецПроцедуры

Функция ПодтвердитьИзмененияСайта(МассивИдентификаторов) Экспорт
	ДанныеДляЗапроса = Новый Структура;
	ДанныеДляЗапроса.Вставить("ids", МассивИдентификаторов);
	Возврат ОтправитьHTTPЗапрос("POST", "api/v1/onec-sync/outbox/ack/", ДанныеДляЗапроса);
КонецФункции

Функция ЗагрузитьИзмененияСайта(Лимит = Неопределено) Экспорт
	РезультатЗагрузки = Новый Структура;
	РезультатЗагрузки.Вставить("Получено", 0);
	РезультатЗагрузки.Вставить("Применено", 0);
	РезультатЗагрузки.Вставить("Подтверждено", 0);
	
	ЛимитЗагрузки = ПолучитьЛимитЗагрузкиИзмененийСайта(Лимит);
	СтрокаЛимита = ПолучитьСтрокуЛимитаОчередиСинхронизации(ЛимитЗагрузки);
	РезультатHTTP = ОтправитьHTTPЗапрос("GET", СтрШаблон("api/v1/onec-sync/outbox/?limit=%1", СтрокаЛимита));
	Если НЕ ЭтоУспешныйКодHTTP(РезультатHTTP.Код) Тогда
		ВызватьИсключение РезультатHTTP.Тело;
	КонецЕсли;
	
	ТелоОтвета = ТекстJSONВОбъект(РезультатHTTP.Тело);
	Изменения = ПолучитьЗначениеJSON(ТелоОтвета, "results", Новый Массив);
	РезультатЗагрузки.Вставить("Получено", Изменения.Количество());
	
	Если Изменения.Количество() = 0 Тогда
		Возврат РезультатЗагрузки;
	КонецЕсли;
	
	МассивПодтверждений = Новый Массив;
	Для каждого Изменение Из Изменения Цикл
		Попытка
			ПрименитьИзменениеСайта(Изменение);
			МассивПодтверждений.Добавить(ПолучитьЗначениеJSON(Изменение, "id"));
			УвеличитьЗначениеСтруктуры(РезультатЗагрузки, "Применено");
		Исключение
			ЗаписьЖурналаРегистрации("Django", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;
	
	Если МассивПодтверждений.Количество() > 0 Тогда
		РезультатПодтверждения = ПодтвердитьИзмененияСайта(МассивПодтверждений);
		Если ЭтоУспешныйКодHTTP(РезультатПодтверждения.Код) Тогда
			РезультатЗагрузки.Вставить("Подтверждено", МассивПодтверждений.Количество());
		Иначе
			ЗаписьЖурналаРегистрации("Django", УровеньЖурналаРегистрации.Ошибка,,,РезультатПодтверждения.Тело);
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатЗагрузки;
КонецФункции

