#Область Обмен
Функция ОтправитьОбъектНаСайт(СсылкаНаОбъект)
	Если ТипЗнч(СсылкаНаОбъект) = Тип("СправочникСсылка.Статьи") Тогда
		Если НЕ СсылкаНаОбъект.Родитель.Пустая() Тогда
			Результат = ОтправитьОбъектНаСайт(СсылкаНаОбъект.Родитель);
			Если НЕ ЭтоУспешныйКодHTTP(Результат.Код) Тогда
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	МассивДанных = СформироватьМаршрутИДанныеДляЗапроса(СсылкаНаОбъект);
	Для каждого МаршрутИДанныеДляЗапроса Из МассивДанных Цикл
		Метод = ПолучитьЗначениеJSON(МаршрутИДанныеДляЗапроса, "Метод", "");
		АдресРесурса = ПолучитьЗначениеJSON(МаршрутИДанныеДляЗапроса, "АдресРесурса", "");
		Если ЗначениеЗаполнено(Метод) И ЗначениеЗаполнено(АдресРесурса) Тогда
			Результат = ОтправитьHTTPЗапрос(Метод, АдресРесурса, МаршрутИДанныеДляЗапроса.ДанныеДляЗапроса);
		Иначе
			//Проверка на существование
			Результат = ОтправитьHTTPЗапрос("HEAD",ПолучитьАдресРесурса(МаршрутИДанныеДляЗапроса.Маршрут,СсылкаНаОбъект));
			Если Результат.Код = 200 Тогда
				Результат = ОтправитьHTTPЗапрос("PATCH",ПолучитьАдресРесурса(МаршрутИДанныеДляЗапроса.Маршрут,СсылкаНаОбъект),МаршрутИДанныеДляЗапроса.ДанныеДляЗапроса);
			ИначеЕсли Результат.Код = 404 Тогда
				Результат = ОтправитьHTTPЗапрос("POST",ПолучитьАдресРесурса(МаршрутИДанныеДляЗапроса.Маршрут),МаршрутИДанныеДляЗапроса.ДанныеДляЗапроса);
			КонецЕсли;
		КонецЕсли;
		Если НЕ ЭтоУспешныйКодHTTP(Результат.Код) Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции 

Функция СформироватьМаршрутИДанныеДляЗапроса(СсылкаНаОбъект)
	МаршрутИДанныеДляЗапроса = Новый Структура;
	ДанныеДляЗапроса = Новый Структура; 
	МассивДанных = новый Массив;
	Если ТипЗнч(СсылкаНаОбъект) = Тип("ДокументСсылка.Автоплатежи") Тогда
		//Основной документ
		МаршрутИДанныеДляЗапроса = Новый Структура;
		ДанныеДляЗапроса = Новый Структура; 
		МаршрутИДанныеДляЗапроса.Вставить("Маршрут","auto-payments");
		ДанныеДляЗапроса.Вставить("id",XMLСтрока(СсылкаНаОбъект));
		ДанныеДляЗапроса.Вставить("number",СсылкаНаОбъект.Номер);
