Процедура ОтработатьОчередьОбновлений()    Экспорт 
	ТипыДокументов = Новый Массив;
    Для каждого метаДок Из Метаданные.Документы Цикл
        ТипыДокументов.Добавить(Тип("ДокументСсылка." + метаДок.Имя));
    КонецЦикла;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	DjСписокОбменаССайтом.СсылкаОбъект КАК СсылкаОбъект,
    |	ВЫБОР
    |		КОГДА ТИПЗНАЧЕНИЯ(DjСписокОбменаССайтом.СсылкаОбъект) В (&ТипыДокументов)
    |			ТОГДА ИСТИНА
    |		ИНАЧЕ ЛОЖЬ
    |	КОНЕЦ КАК ЭтоДокумент,
    |	DjСписокОбменаССайтом.СсылкаОбъект.ЭтоГруппа КАК ЭтоГруппа
    |ИЗ
    |	РегистрСведений.DjСписокОбменаССайтом КАК DjСписокОбменаССайтом
    |
    |УПОРЯДОЧИТЬ ПО
    |	ЭтоДокумент,
    |	ЭтоГруппа УБЫВ";
    Запрос.УстановитьПараметр("ТипыДокументов", ТипыДокументов);
    
    Выборка = Запрос.Выполнить().Выбрать();
    
	МассивУспешных = Новый Массив;
	Пока Выборка.Следующий() Цикл 
		Попытка
			Результат = ОтправитьОбъектНаСайт(Выборка.СсылкаОбъект);
			Если Результат.Код = 200 или Результат.Код = 201 Тогда
				МассивУспешных.Добавить(Выборка.СсылкаОбъект);
			иначе
				ЗаписьЖурналаРегистрации("Django", УровеньЖурналаРегистрации.Ошибка,,,Результат.Тело);
			КонецЕсли; 
			
		Исключение
		    ЗаписьЖурналаРегистрации("Django", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());
		КонецПопытки;
					
	КонецЦикла;	
	Для каждого ВыгруженныйОбъект Из МассивУспешных Цикл
		НаборЗаписей = РегистрыСведений.DjСписокОбменаССайтом.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.СсылкаОбъект.Установить(ВыгруженныйОбъект);
		НаборЗаписей.Записать();
	КонецЦикла;	
КонецПроцедуры

