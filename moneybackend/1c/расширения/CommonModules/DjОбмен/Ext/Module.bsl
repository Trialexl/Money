#Область  Запросы
Функция ОтправитьHTTPЗапрос(Метод, АдресРесурса, ДанныеДляЗапроса = Неопределено) Экспорт 
	DjНастройкиСоединения = ПолучитьНастройкиСоединения();
	Если DjНастройкиСоединения = Неопределено Тогда
		ДанныеВозврата = Новый Структура;
		ДанныеВозврата.Вставить("Код", 0);
		ДанныеВозврата.Вставить("Тело", "Не указаны настройки соединения");
		Возврат ДанныеВозврата;
	КонецЕсли;
	
	Попытка
		HTTPСоединение = СоздатьHTTPСоединение(DjНастройкиСоединения);
	Исключение
		ДанныеВозврата = Новый Структура;
		ДанныеВозврата.Вставить("Код", 0);
		ДанныеВозврата.Вставить("Тело", ОписаниеОшибки());
		Возврат ДанныеВозврата;
	КонецПопытки;
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Authorization", "Token "+ DjНастройкиСоединения.Токен);
	Заголовки.Вставить("Content-Type","application/json");
	Заголовки.Вставить("X-OneC-Sync", "1");
	
	HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
	Если не ДанныеДляЗапроса = Неопределено Тогда
		HTTPЗапрос.УстановитьТелоИзСтроки( СформироватьJSON(ДанныеДляЗапроса),КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	КонецЕсли;
	
	Результат = HTTPСоединение.ВызватьHTTPМетод(Метод, HTTPЗапрос);
	
	ДанныеВозврата = Новый Структура;
	ДанныеВозврата.Вставить("Код", Результат.КодСостояния);
	ДанныеВозврата.Вставить("Тело",Результат.ПолучитьТелоКакСтроку());
	
	Возврат ДанныеВозврата;
КонецФункции

Функция СоздатьHTTPСоединение(НастройкиСоединения)
	ПараметрыСоединения = ПодготовитьПараметрыHTTPСоединения(НастройкиСоединения);
	ЗащищенноеСоединение = Неопределено;
	
	Если ПараметрыСоединения.ИспользоватьHTTPS Тогда
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	КонецЕсли;
	
	Возврат Новый HTTPСоединение(
		ПараметрыСоединения.Адрес,
		ПараметрыСоединения.Порт,
		,
		,
		,
		,
		ЗащищенноеСоединение
	);
КонецФункции

Функция ПодготовитьПараметрыHTTPСоединения(НастройкиСоединения)
	Адрес = СокрЛП(НастройкиСоединения.Адрес);
	Порт = НастройкиСоединения.Порт;
	ИспользоватьHTTPS = Ложь;
	АдресВНижнемРегистре = НРег(Адрес);
	
	Если Лев(АдресВНижнемРегистре, 8) = "https://" Тогда
		ИспользоватьHTTPS = Истина;
		Адрес = Сред(Адрес, 9);
	ИначеЕсли Лев(АдресВНижнемРегистре, 7) = "http://" Тогда
		Адрес = Сред(Адрес, 8);
	ИначеЕсли Порт = 443 Тогда
		ИспользоватьHTTPS = Истина;
	КонецЕсли;
	
	ПозицияСлэша = СтрНайти(Адрес, "/");
	Если ПозицияСлэша > 0 Тогда
		Адрес = Лев(Адрес, ПозицияСлэша - 1);
	КонецЕсли;
	
	Адрес = СокрЛП(Адрес);
	Если НЕ ЗначениеЗаполнено(Адрес) Тогда
		ВызватьИсключение "Не заполнен адрес сервера обмена.";
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Порт) Тогда
		Порт = ?(ИспользоватьHTTPS, 443, 80);
	КонецЕсли;
	
	ПараметрыСоединения = Новый Структура;
	ПараметрыСоединения.Вставить("Адрес", Адрес);
	ПараметрыСоединения.Вставить("Порт", Порт);
	ПараметрыСоединения.Вставить("ИспользоватьHTTPS", ИспользоватьHTTPS);
	Возврат ПараметрыСоединения;
КонецФункции

Функция ПолучитьНастройкиСоединения()
	НастройкиСоединения = РегистрыСведений.DjНастройкиСоединения.Выбрать(Новый Структура("Активно", Истина));
	Если НЕ НастройкиСоединения.Следующий() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат НастройкиСоединения;
КонецФункции

Функция ПолучитьАдресРесурса(URL,СсылкаНаОбъект = Неопределено)
	АдресAPI = "api/v1/";
	Если СсылкаНаОбъект = Неопределено Тогда 
		Возврат СтрШаблон("%1%2/",АдресAPI,URL);
	Иначе                                 
		Возврат СтрШаблон("%1%2/%3/",АдресAPI,URL, XMLСтрока(СсылкаНаОбъект));
	КонецЕсли;	
КонецФункции

Функция СформироватьСтрокиГрафикаДляЗапроса(ТабличнаяЧасть, ИмяПоляПериода)
	СтрокиГрафика = Новый Массив;
	Для каждого СтрокаТабличнойЧасти Из ТабличнаяЧасть Цикл
		СтрокаГрафика = Новый Структура;
		Если ИмяПоляПериода = "Период" Тогда
			СтрокаГрафика.Вставить("date_start", СтрокаТабличнойЧасти.Период);
		ИначеЕсли ИмяПоляПериода = "ПериодБюджетирования" Тогда
			СтрокаГрафика.Вставить("date_start", СтрокаТабличнойЧасти.ПериодБюджетирования);
		Иначе
			ВызватьИсключение СтрШаблон("Неизвестное поле периода табличной части: %1.", ИмяПоляПериода);
		КонецЕсли;
		СтрокаГрафика.Вставить("amount", СтрокаТабличнойЧасти.Сумма);
		СтрокиГрафика.Добавить(СтрокаГрафика);
	КонецЦикла;
	
	Возврат СтрокиГрафика;
КонецФункции

Функция СформироватьЗапросЗаменыГрафика(АдресРесурса, СтрокиГрафика)
	ЗапросНаЗаменуГрафика = Новый Структура;
	ДанныеДляЗапроса = Новый Структура;
	ЗапросНаЗаменуГрафика.Вставить("Метод", "PUT");
	ЗапросНаЗаменуГрафика.Вставить("АдресРесурса", АдресРесурса);
	ДанныеДляЗапроса.Вставить("rows", СтрокиГрафика);
	ЗапросНаЗаменуГрафика.Вставить("ДанныеДляЗапроса", ДанныеДляЗапроса);
	
	Возврат ЗапросНаЗаменуГрафика;
КонецФункции

Функция ЭтоУспешныйКодHTTP(КодСостояния)
	Возврат КодСостояния = 200 ИЛИ КодСостояния = 201 ИЛИ КодСостояния = 204;
КонецФункции

Функция НормализоватьЛимитОчередиСинхронизации(Лимит, ЗначениеПоУмолчанию = 100)
	НормализованныйЛимит = ЗначениеПоУмолчанию;
	
	Если ТипЗнч(Лимит) = Тип("Число") Тогда
		НормализованныйЛимит = Лимит;
	ИначеЕсли ТипЗнч(Лимит) = Тип("Строка") И ЗначениеЗаполнено(Лимит) Тогда
		Попытка
			НормализованныйЛимит = XMLЗначение(Тип("Число"), Лимит);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если НормализованныйЛимит < 1 Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Если НормализованныйЛимит > 5000 Тогда
		Возврат 5000;
	КонецЕсли;
	
	Возврат НормализованныйЛимит;
КонецФункции

Функция ПолучитьЛимитЗагрузкиИзмененийСайта(Лимит = Неопределено)
	Если Лимит <> Неопределено Тогда
		Возврат НормализоватьЛимитОчередиСинхронизации(Лимит);
	КонецЕсли;
	
	НастройкиСоединения = ПолучитьНастройкиСоединения();
	Если НастройкиСоединения = Неопределено Тогда
		Возврат 100;
	КонецЕсли;
	
	Возврат НормализоватьЛимитОчередиСинхронизации(НастройкиСоединения.ЛимитОчередиСинхронизации);
КонецФункции

Функция ПолучитьСтрокуЛимитаОчередиСинхронизации(Лимит)
	Цифры = "0123456789";
	ЦелыйЛимит = Цел(НормализоватьЛимитОчередиСинхронизации(Лимит));
	СтрокаЛимита = "";
	
	Если ЦелыйЛимит <= 0 Тогда
		Возврат "100";
	КонецЕсли;
	
	Пока ЦелыйЛимит > 0 Цикл
		Остаток = ЦелыйЛимит - 10 * Цел(ЦелыйЛимит / 10);
		СтрокаЛимита = Сред(Цифры, Остаток + 1, 1) + СтрокаЛимита;
		ЦелыйЛимит = Цел(ЦелыйЛимит / 10);
	КонецЦикла;
	
	Возврат СтрокаЛимита;
КонецФункции


	 
#КонецОбласти


#Область ВспомогательныеФункции
Функция ПолучитьЗначениеJSON(Контейнер, ИмяКлюча, ЗначениеПоУмолчанию = Неопределено)
	Перем Значение;
	Если Контейнер = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Если ТипЗнч(Контейнер) = Тип("Соответствие") Тогда
		Значение = Контейнер.Получить(ИмяКлюча);
		Если Значение <> Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Контейнер) = Тип("Структура") Тогда
		Если Контейнер.Свойство(ИмяКлюча, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция НормализоватьДатуJSON(Значение, ЗначениеПоУмолчанию = Неопределено)
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Дата") Тогда
		Возврат Значение;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Строка") И ЗначениеЗаполнено(Значение) Тогда
		Попытка
			Возврат XMLЗначение(Тип("Дата"), Значение);
		Исключение
		КонецПопытки;
	КонецЕсли;

	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПолучитьДатуJSON(Контейнер, ИмяКлюча, ЗначениеПоУмолчанию = Неопределено)
	Возврат НормализоватьДатуJSON(ПолучитьЗначениеJSON(Контейнер, ИмяКлюча), ЗначениеПоУмолчанию);
КонецФункции

Функция НормализоватьЧислоJSON(Значение, ЗначениеПоУмолчанию = 0)
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Строка") И ЗначениеЗаполнено(Значение) Тогда
		Попытка
			Возврат XMLЗначение(Тип("Число"), Значение);
		Исключение
		КонецПопытки;
	КонецЕсли;

	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПолучитьЧислоJSON(Контейнер, ИмяКлюча, ЗначениеПоУмолчанию = 0)
	Возврат НормализоватьЧислоJSON(ПолучитьЗначениеJSON(Контейнер, ИмяКлюча), ЗначениеПоУмолчанию);
КонецФункции

Процедура УвеличитьЗначениеСтруктуры(СтруктураЗначений, ИмяПоля, Шаг = 1)
	ТекущееЗначение = 0;
	СтруктураЗначений.Свойство(ИмяПоля, ТекущееЗначение);
	СтруктураЗначений.Вставить(ИмяПоля, ТекущееЗначение + Шаг);
КонецПроцедуры

Функция ПолучитьСсылкуПоUUID(МенеджерОбъекта, СтрокаUUID)
	Если НЕ ЗначениеЗаполнено(СтрокаUUID) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаUUID));
КонецФункции

Функция ПолучитьСсылкуПоМаршруту(Маршрут, СтрокаUUID)
	Если НЕ ЗначениеЗаполнено(СтрокаUUID) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Маршрут = "wallets" Тогда
		Возврат ПолучитьСсылкуПоUUID(Справочники.Кошельки, СтрокаUUID);
	ИначеЕсли Маршрут = "projects" Тогда
		Возврат ПолучитьСсылкуПоUUID(Справочники.Проекты, СтрокаUUID);
	ИначеЕсли Маршрут = "cash-flow-items" Тогда
		Возврат ПолучитьСсылкуПоUUID(Справочники.Статьи, СтрокаUUID);
	ИначеЕсли Маршрут = "users" Тогда
		Возврат ПолучитьСсылкуПоUUID(Справочники.Контрагенты, СтрокаUUID);
	ИначеЕсли Маршрут = "receipts" Тогда
		Возврат ПолучитьСсылкуПоUUID(Документы.Приходы, СтрокаUUID);
	ИначеЕсли Маршрут = "expenditures" Тогда
		Возврат ПолучитьСсылкуПоUUID(Документы.Расходы, СтрокаUUID);
	ИначеЕсли Маршрут = "transfers" Тогда
		Возврат ПолучитьСсылкуПоUUID(Документы.Переводы, СтрокаUUID);
	ИначеЕсли Маршрут = "budgets" Тогда
		Возврат ПолучитьСсылкуПоUUID(Документы.Бюджет, СтрокаUUID);
	ИначеЕсли Маршрут = "auto-payments" Тогда
		Возврат ПолучитьСсылкуПоUUID(Документы.Автоплатежи, СтрокаUUID);
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Функция СоздатьОбъектПоМаршруту(Маршрут)
	Если Маршрут = "wallets" Тогда
		Возврат Справочники.Кошельки.СоздатьЭлемент();
	ИначеЕсли Маршрут = "projects" Тогда
		Возврат Справочники.Проекты.СоздатьЭлемент();
	ИначеЕсли Маршрут = "cash-flow-items" Тогда
		Возврат Справочники.Статьи.СоздатьЭлемент();
	ИначеЕсли Маршрут = "users" Тогда
		Возврат Справочники.Контрагенты.СоздатьЭлемент();
	ИначеЕсли Маршрут = "receipts" Тогда
		Возврат Документы.Приходы.СоздатьДокумент();
	ИначеЕсли Маршрут = "expenditures" Тогда
		Возврат Документы.Расходы.СоздатьДокумент();
	ИначеЕсли Маршрут = "transfers" Тогда
		Возврат Документы.Переводы.СоздатьДокумент();
	ИначеЕсли Маршрут = "budgets" Тогда
		Возврат Документы.Бюджет.СоздатьДокумент();
	ИначеЕсли Маршрут = "auto-payments" Тогда
		Возврат Документы.Автоплатежи.СоздатьДокумент();
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Функция ПолучитьИлиСоздатьОбъектПоМаршруту(Маршрут, СтрокаUUID)
	СсылкаНаОбъект = ПолучитьСсылкуПоМаршруту(Маршрут, СтрокаUUID);
	Если СсылкаНаОбъект = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Не удалось получить ссылку по маршруту %1.", Маршрут);
	КонецЕсли;
	
	Объект = Неопределено;
	Попытка
		Объект = СсылкаНаОбъект.ПолучитьОбъект();
	Исключение
	КонецПопытки;
	Если Объект <> Неопределено Тогда
		Возврат Объект;
	КонецЕсли;
	
	Объект = СоздатьОбъектПоМаршруту(Маршрут);
	Если Объект = Неопределено Тогда
		ВызватьИсключение СтрШаблон("Не удалось создать объект по маршруту %1.", Маршрут);
	КонецЕсли;
	
	Объект.УстановитьСсылкуНового(СсылкаНаОбъект);
	Возврат Объект;
КонецФункции

Процедура ЗаписатьОбъектИзОбмена(Объект)
	Если Объект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Объект.ОбменДанными.Загрузка = Истина;
	Объект.Записать();
КонецПроцедуры

Процедура ЗаполнитьГрафикДокумента(ТабличнаяЧасть, МассивСтрокГрафика, ИмяПоляПериода)
	ТабличнаяЧасть.Очистить();
	Если МассивСтрокГрафика = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаГрафика Из МассивСтрокГрафика Цикл
		НоваяСтрока = ТабличнаяЧасть.Добавить();
		Если ИмяПоляПериода = "Период" Тогда
			НоваяСтрока.Период = ПолучитьДатуJSON(СтрокаГрафика, "date_start");
		ИначеЕсли ИмяПоляПериода = "ПериодБюджетирования" Тогда
			НоваяСтрока.ПериодБюджетирования = ПолучитьДатуJSON(СтрокаГрафика, "date_start");
		Иначе
			ВызватьИсключение СтрШаблон("Неизвестное поле периода табличной части: %1.", ИмяПоляПериода);
		КонецЕсли;
		НоваяСтрока.Сумма = ПолучитьЧислоJSON(СтрокаГрафика, "amount");
	КонецЦикла;
КонецПроцедуры

Процедура ПрименитьПометкуУдаления(Маршрут, СтрокаUUID, ПолезнаяНагрузка)
	СсылкаНаОбъект = ПолучитьСсылкуПоМаршруту(Маршрут, СтрокаUUID);
	Если СсылкаНаОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		Объект = СсылкаНаОбъект.ПолучитьОбъект();
	Исключение
		Возврат;
	КонецПопытки;
	
	Если Маршрут = "users" Тогда
		Объект.ПометкаУдаления = НЕ ПолучитьЗначениеJSON(ПолезнаяНагрузка, "is_active", Ложь);
	Иначе
		Объект.ПометкаУдаления = Истина;
	КонецЕсли;
	
	ЗаписатьОбъектИзОбмена(Объект);
КонецПроцедуры

Процедура ЗаполнитьОбъектИзСайта(Маршрут, Объект, ПолезнаяНагрузка)
	Если Маршрут = "wallets" Тогда
		Объект.Код = ПолучитьЗначениеJSON(ПолезнаяНагрузка, "code");
		Объект.Наименование = ПолучитьЗначениеJSON(ПолезнаяНагрузка, "name");
