
#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьНаСервере();  
	Элементы.СписокВыгрузки.Обновить();
КонецПроцедуры

&НаСервере
Процедура ОбновитьНаСервере()
	DjОбмен.ОтработатьОчередьОбновлений();
	СтатистикаЗагрузки = DjОбмен.ЗагрузитьИзмененияСайта();
	Результат = СтрШаблон(
		"Исходящая очередь отправлена. Из Django получено: %1, применено: %2, подтверждено: %3.",
		СтатистикаЗагрузки.Получено,
		СтатистикаЗагрузки.Применено,
		СтатистикаЗагрузки.Подтверждено
	);
КонецПроцедуры

&НаСервере
Процедура ПолнаяВыгрузкаНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Кошельки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Кошельки КАК Кошельки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Статьи.Ссылка
		|ИЗ
		|	Справочник.Статьи КАК Статьи
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Проекты.Ссылка
		|ИЗ
		|	Справочник.Проекты КАК Проекты
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Приходы.Ссылка
		|ИЗ
		|	Документ.Приходы КАК Приходы
		|ГДЕ
		|	Приходы.Дата >= &Дата
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Расходы.Ссылка
		|ИЗ
		|	Документ.Расходы КАК Расходы
		|ГДЕ
		|	Расходы.Дата >= &Дата
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Переводы.Ссылка
		|ИЗ
		|	Документ.Переводы КАК Переводы
		|ГДЕ
		|	Переводы.Дата >= &Дата
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Бюджет.Ссылка
		|ИЗ
		|	Документ.Бюджет КАК Бюджет
		|ГДЕ
		|	Бюджет.Дата >= &Дата
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Автоплатежи.Ссылка
		|ИЗ
		|	Документ.Автоплатежи КАК Автоплатежи
		|ГДЕ
		|	Автоплатежи.Дата >= &Дата";
	Запрос.УстановитьПараметр("Дата",СКакойДаты);
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РегистрыСведений.DjСписокОбменаССайтом.ДобавитьЗапись(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПолнаяВыгрузка(Команда)
	ПолнаяВыгрузкаНаСервере();
КонецПроцедуры



&НаСервере
Процедура ВыгрузкаСправочниковНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Кошельки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Кошельки КАК Кошельки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Статьи.Ссылка
		|ИЗ
		|	Справочник.Статьи КАК Статьи
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Проекты.Ссылка
		|ИЗ
		|	Справочник.Проекты КАК Проекты";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РегистрыСведений.DjСписокОбменаССайтом.ДобавитьЗапись(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	

КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаСправочников(Команда)
	ВыгрузкаСправочниковНаСервере();
КонецПроцедуры

#КонецОбласти
