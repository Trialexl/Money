# Django Settings
SECRET_KEY=your-very-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=
USE_X_FORWARDED_HOST=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
WEB_BIND_HOST=127.0.0.1
WEB_PORT=18000

# Database
DB_HOST=localhost
DB_NAME=djangolk
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# AI assistant
AI_DEFAULT_PROVIDER=openrouter
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=google/gemini-2.5-flash
AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
AI_OPENROUTER_SITE_URL=
AI_OPENROUTER_APP_NAME=djangolk
AI_OPENAI_API_KEY=
AI_OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
AI_OPENAI_TRANSCRIBE_BASE_URL=https://api.openai.com/v1/audio/transcriptions
AI_OPENAI_TRANSCRIBE_LANGUAGE=ru
AI_OPENAI_TRANSCRIBE_PROMPT=
AI_ALLOW_RULE_BASED_FALLBACK=True
AI_TELEGRAM_BOT_SECRET=
AI_TELEGRAM_BOT_TOKEN=
AI_TELEGRAM_API_BASE_URL=https://api.telegram.org
AI_DUPLICATE_WINDOW_SECONDS=600
